<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistem Irigare Automatizată | Bare-Metal AVR</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">

    <style>
        /* ================= VARIABLES ================= */
        :root {
            --bg-color: #0a0a0c;
            --surface-color: #161b22;
            --border-color: #30363d;
            --text-main: #c9d1d9;
            --text-muted: #8b949e;
            --accent-green: #00ff66;
            --accent-amber: #ffb000;
            --font-display: 'Share Tech Mono', monospace;
            --font-code: 'JetBrains Mono', monospace;
        }

        /* ================= RESET & BASE ================= */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: var(--font-code);
            line-height: 1.6;
            overflow-x: hidden;
            background-image: 
                linear-gradient(rgba(0, 255, 102, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 255, 102, 0.03) 1px, transparent 1px);
            background-size: 30px 30px;
        }

        h1, h2, h3 {
            font-family: var(--font-display);
            font-weight: 400;
            color: var(--accent-green);
        }

        a { text-decoration: none; color: var(--accent-green); transition: 0.3s; }
        a:hover { color: var(--accent-amber); text-shadow: 0 0 8px rgba(255,176,0,0.5); }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* ================= ANIMATIONS ================= */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.5, 0, 0, 1);
        }
        .reveal.active { opacity: 1; transform: translateY(0); }

        @keyframes blinkCursor {
            50% { border-right-color: transparent; }
        }
        
        @keyframes scanline {
            0% { transform: translateY(-100%); }
            100% { transform: translateY(100vh); }
        }

        /* Scanline effect */
        .scanline {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 10px;
            background: rgba(0, 255, 102, 0.1);
            opacity: 0.4;
            pointer-events: none;
            animation: scanline 8s linear infinite;
            z-index: 9999;
        }

        /* ================= HERO SECTION ================= */
        .hero {
            min-height: 90vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            border-bottom: 1px solid var(--border-color);
            position: relative;
        }

        .terminal-header {
            color: var(--text-muted);
            margin-bottom: 20px;
            font-size: 0.9rem;
        }

        .hero h1 {
            font-size: clamp(2rem, 5vw, 4rem);
            margin-bottom: 20px;
            text-shadow: 0 0 10px rgba(0, 255, 102, 0.3);
            border-right: 3px solid var(--accent-green);
            white-space: nowrap;
            overflow: hidden;
            width: fit-content;
            animation: blinkCursor 0.8s step-end infinite;
        }

        .hero p {
            font-size: 1.2rem;
            color: var(--text-muted);
            max-width: 700px;
            margin-bottom: 40px;
        }

        .btn {
            display: inline-block;
            padding: 12px 24px;
            border: 1px solid var(--accent-green);
            background: transparent;
            color: var(--accent-green);
            font-family: var(--font-display);
            font-size: 1.1rem;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .btn:hover {
            background: var(--accent-green);
            color: var(--bg-color);
            box-shadow: 0 0 20px rgba(0, 255, 102, 0.4);
        }

        /* ================= SECTIONS ================= */
        section { padding: 80px 0; border-bottom: 1px solid var(--border-color); }
        .section-title { font-size: 2rem; margin-bottom: 40px; position: relative; display: inline-block;}
        .section-title::after {
            content: ''; position: absolute; bottom: -5px; left: 0;
            width: 50%; height: 2px; background: var(--accent-green);
        }

        /* ================= GRID SPECS ================= */
        .specs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .spec-item {
            background: var(--surface-color);
            padding: 20px;
            border-left: 3px solid var(--border-color);
            transition: 0.3s;
        }

        .spec-item:hover {
            border-left-color: var(--accent-amber);
            transform: translateX(5px);
        }

        .spec-item h3 { font-size: 1.2rem; margin-bottom: 10px; color: var(--text-main); }
        .spec-item p { color: var(--text-muted); font-size: 0.9rem; }

        /* ================= ARCHITECTURE ================= */
        .arch-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--surface-color);
            padding: 40px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .node {
            flex: 1; min-width: 200px;
            text-align: center;
            padding: 30px;
            border: 1px dashed var(--accent-green);
            background: rgba(0,255,102,0.05);
        }

        .connection {
            display: flex; flex-direction: column; align-items: center;
            color: var(--accent-amber); font-family: var(--font-display);
        }
        
        .arrow { font-size: 2rem; margin: -10px 0; }

        /* ================= DRIVERS ================= */
        .drivers-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .driver-card {
            background: var(--surface-color);
            border: 1px solid var(--border-color);
            padding: 25px;
            transition: all 0.3s ease;
            position: relative;
        }

        .driver-card::before {
            content: ''; position: absolute; top: 0; left: 0; width: 10px; height: 10px;
            border-top: 2px solid transparent; border-left: 2px solid transparent; transition: 0.3s;
        }

        .driver-card:hover {
            border-color: var(--accent-green);
            box-shadow: 0 0 15px rgba(0, 255, 102, 0.1);
        }

        .driver-card:hover::before { border-color: var(--accent-green); }

        .driver-card h3 { color: var(--accent-green); margin-bottom: 15px; font-size: 1.3rem; }
        .driver-card ul { list-style: none; color: var(--text-muted); font-size: 0.9rem; margin-top: 15px;}
        .driver-card ul li::before { content: '>'; color: var(--accent-amber); margin-right: 8px; }

        /* ================= BUILD SYSTEM & TERMINAL ================= */
        .terminal-window {
            background: #0d1117;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            overflow: hidden;
            margin-top: 20px;
        }

        .terminal-bar {
            background: #161b22; border-bottom: 1px solid var(--border-color);
            padding: 10px 15px; display: flex; gap: 8px;
        }

        .dot { width: 12px; height: 12px; border-radius: 50%; }
        .dot.r { background: #ff5f56; } .dot.y { background: #ffbd2e; } .dot.g { background: #27c93f; }

        .terminal-body { padding: 20px; overflow-x: auto; }
        .terminal-body pre { color: var(--text-main); font-size: 0.9rem; }
        .prompt { color: var(--accent-green); }
        .comment { color: #8b949e; }

        .file-tree {
            color: var(--text-muted);
            line-height: 1.4;
            font-size: 0.9rem;
            background: var(--surface-color);
            padding: 20px; border: 1px solid var(--border-color);
        }

        /* ================= FOOTER ================= */
        footer { text-align: center; padding: 60px 0; }
        
        /* ================= RESPONSIVE ================= */
        @media (max-width: 768px) {
            .hero h1 { animation: none; white-space: normal; border-right: none; }
            .arch-container { flex-direction: column; }
            .connection { transform: rotate(90deg); margin: 20px 0; }
        }
    </style>
</head>
<body>

    <div class="scanline"></div>

    <div class="container">
        <header class="hero reveal">
            <div class="terminal-header">sysadmin@local:~/projects/smart-irrigation$ ./run_presentation.sh</div>
            <h1 id="typewriter">Sistem_Irigare_Automatizată</h1>
            <p>Arhitectură Master-Slave. Implementare integrală în C bare-metal. Manipulare directă a regiștrilor AVR, fără framework-uri sau librării terțe.</p>
            <div>
                <a href="https://github.com/razvanstefandima-11/Sistem-Automat-de-Irigare-pentru-Plante" target="_blank" class="btn">View Source pe GitHub_</a>
            </div>
        </header>

        <section class="reveal">
            <h2 class="section-title">Hardware_Specs</h2>
            <div class="specs-grid">
                <div class="spec-item">
                    <h3>MCU Principal</h3>
                    <p>Arduino Uno (ATmega328P). Rol de Master. Gestionează logica decizională, interfața I2C și senzorul ultrasonic.</p>
                </div>
                <div class="spec-item">
                    <h3>MCU Secundar</h3>
                    <p>Arduino Nano. Rol de Slave. Achiziție date senzori (ADC) și acționare elemente de execuție (GPIO/Pompe).</p>
                </div>
                <div class="spec-item">
                    <h3>Senzori & Actuatori</h3>
                    <p>3x Senzori umiditate capacitivi (ADC 10-bit)<br>1x HC-SR04 (Nivel apă)<br>Pompe apă via Relee/Tranzistori</p>
                </div>
                <div class="spec-item">
                    <h3>Interfață (HMI)</h3>
                    <p>Display LCD 1602 controlat exclusiv prin modul TWI/I2C. Alarme sonore (Buzzer) și vizuale (LED).</p>
                </div>
            </div>
        </section>

        <section class="reveal">
            <h2 class="section-title">Arhitectură_Sistem</h2>
            <div class="arch-container">
                <div class="node">
                    <h3>MASTER (Uno)</h3>
                    <p style="color:var(--text-muted); font-size:0.9em; margin-top:10px;">
                        [Logic Control]<br>
                        Display LCD (I2C)<br>
                        Ultrasonic (Timer/EXTI)<br>
                        EEPROM (Thresholds)
                    </p>
                </div>
                
                <div class="connection">
                    <span>Protocol I2C/TWI</span>
                    <span class="arrow">⇄</span>
                    <span>Polling / Interrupts</span>
                </div>

                <div class="node">
                    <h3>SLAVE (Nano)</h3>
                    <p style="color:var(--text-muted); font-size:0.9em; margin-top:10px;">
                        [Data & Actuation]<br>
                        Capacitive Sensors (ADC)<br>
                        Water Pumps (GPIO)
                    </p>
                </div>
            </div>
        </section>

        <section class="reveal">
            <h2 class="section-title">HAL_Drivers (Bare-Metal)</h2>
            <div class="drivers-grid">
                <div class="driver-card">
                    <h3>GPIO_Driver</h3>
                    <p>Configurare directă a regiștrilor DDRx, PORTx, PINx pentru I/O digital.</p>
                    <ul>
                        <li>Setare pini In/Out</li>
                        <li>Pull-up resistor config</li>
                        <li>Bit masking optimizat</li>
                    </ul>
                </div>
                <div class="driver-card">
                    <h3>ADC_Driver</h3>
                    <p>Achiziție de date pentru senzorii de umiditate folosind convertorul pe 10-bit.</p>
                    <ul>
                        <li>Modificare ADMUX / ADCSRA</li>
                        <li>Single conversion mode</li>
                        <li>Interrupt-driven optional</li>
                    </ul>
                </div>
                <div class="driver-card">
                    <h3>Timer_Driver</h3>
                    <p>Implementare tick de sistem și delay-uri non-blocante.</p>
                    <ul>
                        <li>Timer0 in CTC Mode (1ms tick)</li>
                        <li>Calcul precis al distanței (HC-SR04)</li>
                    </ul>
                </div>
                <div class="driver-card">
                    <h3>I2C_TWI_Driver</h3>
                    <p>Comunicație serială sincronă implementată hardware.</p>
                    <ul>
                        <li>Master/Slave config via TWCR</li>
                        <li>Transmitere date către LCD 1602</li>
                        <li>Rutine de Error Handling</li>
                    </ul>
                </div>
                <div class="driver-card">
                    <h3>EEPROM_Memory</h3>
                    <p>Persistența datelor critice la repornire.</p>
                    <ul>
                        <li>Salvare praguri umiditate</li>
                        <li>Prevenire suprascriere (wear leveling basic)</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="reveal">
            <h2 class="section-title">Build_System & Testing</h2>
            
            <div class="specs-grid" style="margin-bottom: 20px;">
                <div class="spec-item">
                    <h3>Makefile + AVR-GCC</h3>
                    <p>Compilare curată, gestionare dependențe și target-uri automate. Fără IDE-uri bloated.</p>
                </div>
                <div class="spec-item">
                    <h3>Unit Testing</h3>
                    <p>Rulare teste pe Host PC folosind register mocking. Acoperire de cod verificată prin `lcov`.</p>
                </div>
            </div>

            <div class="terminal-window">
                <div class="terminal-bar">
                    <div class="dot r"></div><div class="dot y"></div><div class="dot g"></div>
                </div>
                <div class="terminal-body">
<pre>
<span class="comment"># Compilare proiect pentru target (ATmega328P)</span>
<span class="prompt">sysadmin@local:~$</span> make all
avr-gcc -Wall -Os -mmcu=atmega328p -c src/main.c -o build/main.o
avr-gcc -Wall -Os -mmcu=atmega328p -c src/gpio.c -o build/gpio.o
...
avr-objcopy -O ihex build/firmware.elf build/firmware.hex
<span style="color:var(--accent-green)">[SUCCESS] Build complete.</span>

<span class="comment"># Upload via avrdude</span>
<span class="prompt">sysadmin@local:~$</span> make flash
avrdude -c arduino -p atmega328p -P /dev/ttyUSB0 -b 115200 -U flash:w:build/firmware.hex
<span style="color:var(--accent-green)">[SUCCESS] Flash complete.</span>
</pre>
                </div>
            </div>
        </section>

        <footer class="reveal">
            <a href="https://github.com/razvanstefandima-11/Sistem-Automat-de-Irigare-pentru-Plante" target="_blank" class="btn">Accesare Repository GitHub_</a>
            <p style="margin-top: 20px; color: var(--text-muted); font-size: 0.8rem;">
                Dezvoltat cu pasiune pentru sistemele embedded.
            </p>
        </footer>
    </div>

    <script>
        // Efect simplu de Typewriter pentru Hero pentru browserele care nu suporta animatia CSS complet
        const titleElement = document.getElementById('typewriter');
        const text = titleElement.innerText;
        titleElement.innerText = '';
        let i = 0;
        
        function typeWriter() {
            if (i < text.length) {
                titleElement.innerHTML += text.charAt(i);
                i++;
                setTimeout(typeWriter, 50); // viteza de scriere
            }
        }
        
        // Pornim efectul de typewriter cand se incarca pagina
        window.onload = () => {
            setTimeout(typeWriter, 500);
        };

        // Scroll Reveal logic folosind IntersectionObserver
        const revealElements = document.querySelectorAll('.reveal');

        const revealOptions = {
            threshold: 0.15,
            rootMargin: "0px 0px -50px 0px"
        };

        const revealOnScroll = new IntersectionObserver(function(entries, observer) {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                    observer.unobserve(entry.target); // Animam doar o data
                }
            });
        }, revealOptions);

        revealElements.forEach(el => {
            revealOnScroll.observe(el);
        });
    </script>
</body>
</html>
